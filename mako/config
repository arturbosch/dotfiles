# Sandstone — minimal mako config
font=JetBrainsMono Nerd Font Propo 11
anchor=top-right
margin=10
padding=12
border-size=2
border-radius=6
default-timeout=5000
max-visible=5

background-color=#18181b
text-color=#ffffff
border-color=#e6d5b8
progress-color=over #3f3f46

[urgency=low]
border-color=#52525b

[urgency=high]
border-color=#e35149
default-timeout=0

[mode=do-not-disturb]
invisible=1
